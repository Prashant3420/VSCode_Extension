{
  "$schema": "https://raw.githubusercontent.com/DotNetAnalyzers/StyleCopAnalyzers/master/StyleCop.Analyzers/StyleCop.Analyzers/Settings/stylecop.schema.json",
  "settings": {
    "documentationRules": {
      "companyName": "Code Quality Guardian",
      "copyrightText": "Copyright (c) {companyName}. All rights reserved.",
      "headerDecoration": "--------------------------------------------------------------",
      "documentInterfaces": false,
      "documentExposedElements": true,
      "documentInternalElements": false,
      "documentPrivateElements": false,
      "documentPrivateFields": false,
      "leadingPriorities": {
        "SA1633": 100
      }
    },
    "orderingRules": {
      "usingDirectivesPlacement": "outsideNamespace",
      "elementOrder": [
        "constant",
        "field",
        "constructor",
        "destructor",
        "delegate",
        "event",
        "enum",
        "interface",
        "property",
        "indexer",
        "method",
        "struct",
        "class"
      ],
      "systemUsingDirectivesFirst": true,
      "sortSystemUsingDirectives": true
    },
    "namingRules": {
      "includeInferredTupleElementNames": false,
      "tupleElementNameIndicators": "Item, Value",
      "allowedHungarianPrefixes": [
        "as",
        "do",
        "id",
        "if",
        "in",
        "is",
        "my",
        "no",
        "on",
        "or",
        "to",
        "ui"
      ],
      "reservedHungarianPrefixes": [
        "ac",
        "bDone",
        "bFlag",
        "bHold",
        "bOn",
        "c",
        "ca",
        "casa",
        "cb",
        "db",
        "dl",
        "ds",
        "dw",
        "f",
        "fc",
        "fn",
        "g",
        "hwnd",
        "i",
        "j",
        "l",
        "lp",
        "ls",
        "m",
        "n",
        "p",
        "pfn",
        "ph",
        "pi",
        "pp",
        "ps",
        "pw",
        "pwsz",
        "r",
        "s",
        "sa",
        "sb",
        "ss",
        "st",
        "sz",
        "tm",
        "u",
        "udt",
        "ui",
        "ul",
        "us",
        "ws",
        "wstr"
      ]
    },
    "maintainabilityRules": {
      "accessModifierDelay": 3,
      "fileMayContainPartialClasses": false,
      "removeCodeRegionMarkers": true,
      "typesToExposePublicly": [
        "class",
        "interface",
        "struct",
        "enum"
      ]
    },
    "layoutRules": {
      "newlineAtEndOfFile": "allow",
      "allowConsecutiveBrackets": false,
      "allowDoWhileOnClosingBrace": false,
      "allowElseBlockWithoutBrace": false,
      "allowEmptyBracesWithoutBrace": false,
      "allowEmptyCatchBlock": false,
      "allowEmptyEmbeddedStatementWithoutBrace": false,
      "allowIfBlockWithoutBrace": false,
      "allowRegionComment": false,
      "allowStatementWithoutBrace": false,
      "closingBracketsMustBeIndented": false,
      "containsComment": true,
      "emptyLineAfterClosingBrace": true,
      "ignoreConsecutiveBrackets": false,
      "insertLineBreakAfterClosingBrace": true,
      "insertLineBreakBeforeElseKeyword": true,
      "insertLineBreakBeforeFinallyKeyword": true,
      "insertLineBreakBeforeWhileKeywordInDoStatement": false,
      "insertLineBreakInList": false,
      "preserveSingeLineBlocks": false,
      "removeBlankLinesBetweenChainedStatements": false,
      "requireBlankLinesAfterChainedStatementBlocks": false,
      "requireBlankLinesAfterCloseBrace": false,
      "requireBlankLinesAfterComma": false,
      "requireBlankLinesAfterDeclaration": false,
      "requireBlankLinesAfterMultilineStatement": false,
      "requireBlankLinesBeforeChainedStatementBlocks": false,
      "requireBlankLinesBetweenChainedStatements": false,
      "requireClosingBraceInsideMultilineExpression": false,
      "requireNewLineBeforeElseKeyword": true,
      "requireNewLineBeforeFinallyKeyword": true,
      "requireNewLineBeforeWhileKeywordInDoStatement": false,
      "requireNewLinesAtStartOfMultiLineStatement": false,
      "useTabs": false
    },
    "readabilityRules": {
      "allowBuiltInTypeAliases": false,
      "allowedKeywords": [
        "add",
        "as",
        "base",
        "bool",
        "break",
        "case",
        "catch",
        "class",
        "const",
        "continue",
        "decimal",
        "default",
        "delegate",
        "do",
        "double",
        "else",
        "enum",
        "event",
        "explicit",
        "extern",
        "false",
        "finally",
        "fixed",
        "float",
        "for",
        "foreach",
        "goto",
        "if",
        "implicit",
        "in",
        "int",
        "interface",
        "internal",
        "is",
        "lock",
        "long",
        "namespace",
        "new",
        "null",
        "object",
        "operator",
        "out",
        "override",
        "params",
        "private",
        "protected",
        "public",
        "readonly",
        "ref",
        "return",
        "sbyte",
        "sealed",
        "short",
        "sizeof",
        "stackalloc",
        "static",
        "string",
        "struct",
        "switch",
        "this",
        "throw",
        "true",
        "try",
        "typeof",
        "uint",
        "ulong",
        "unchecked",
        "unsafe",
        "ushort",
        "using",
        "virtual",
        "void",
        "volatile",
        "while"
      ]
    },
    "spacingRules": {
      "allowArithmeticBinaryOperatorsPadding": true,
      "allowAssignmentOperatorsPadding": true,
      "allowCommasPadding": true,
      "allowMarkersPadding": true,
      "allowMemberAccessOnRightSideOfNonNullConditionalOperator": true,
      "allowNullKeywordOnRightSideOfNonNullConditionalOperator": false,
      "allowParenthesesOnHigherPrecedenceExpressionTypes": false,
      "allowSemicolonPadding": false
    }
  }
}